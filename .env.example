# ============================================================
# Distributed File Storage System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Backend ---
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/dfs_db

# File chunking
CHUNK_SIZE_BYTES=1048576   # 1 MB in bytes

# Storage nodes (comma-separated URLs)
STORAGE_NODES=http://node1:4001,http://node2:4002,http://node3:4003

# Number of virtual nodes per physical node in consistent hash ring
VIRTUAL_NODES=150

# --- Frontend ---
REACT_APP_API_URL=http://localhost:5000/api
